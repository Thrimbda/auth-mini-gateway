HOST=0.0.0.0
PORT=3000
# Empty/unset keeps auth_request adapter mode. Proxy mode example:
# UPSTREAM_URL=http://127.0.0.1:4096
UPSTREAM_URL=
GATEWAY_PUBLIC_BASE_URL=http://localhost:8080
AUTH_MINI_ISSUER=http://127.0.0.1:7777
AUTH_MINI_PUBLIC_BASE_URL=http://localhost:7777
AUTH_MINI_LOGIN_URL=
GATEWAY_DB=./auth-mini-gateway.sqlite
GATEWAY_COOKIE_SECRET=replace-with-at-least-32-random-characters
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
ALLOW_EMAILS=allowed@example.com
ALLOW_USER_IDS=
SESSION_TTL_SECONDS=604800
SESSION_ABSOLUTE_TTL_SECONDS=2592000
SESSION_TOUCH_INTERVAL_SECONDS=3600
LOGIN_STATE_TTL_SECONDS=600
REFRESH_SKEW_SECONDS=60
LOGOUT_REDIRECT=/
